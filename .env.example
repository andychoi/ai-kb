# Self-hosted git remote (Gitea or GitLab). Push token / SSH key configured outside this file.
KB_GIT_REMOTE=git@gitea.example:andychoi/ai-kb.git

# Bot identity for automated commits (Phases 2–4). Interactive commits use the user's git config.
KB_BOT_NAME="kb-bot"
KB_BOT_EMAIL="kb-bot@local"

# Phase 4 webhook receiver — set ONLY in .env (gitignored), never .env.example.
# All three are required for the corresponding endpoint to accept requests.
# Without them set, the endpoint returns 503 (not configured).

# HTTP port the FastAPI server binds on 127.0.0.1
# KB_WEBHOOK_PORT=8765

# Shared secret configured in your GitHub webhook settings (sha256 HMAC body).
# Generate with: openssl rand -hex 32
# GITHUB_WEBHOOK_SECRET=

# Bearer token your mail forwarder sends in Authorization: Bearer <token>.
# Generate with: openssl rand -hex 32
# KB_EMAIL_TOKEN=

# Bearer token for the admin-only /webhook/rss/refresh endpoint.
# Generate with: openssl rand -hex 32
# KB_ADMIN_TOKEN=
