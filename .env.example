# Self-hosted git remote (Gitea or GitLab). Push token / SSH key configured outside this file.
KB_GIT_REMOTE=git@gitea.example:andychoi/ai-kb.git

# Bot identity for automated commits (Phases 2–4). Interactive commits use the user's git config.
KB_BOT_NAME="kb-bot"
KB_BOT_EMAIL="kb-bot@local"

# Optional: future webhook receiver port (Phase 4)
# KB_WEBHOOK_PORT=8765
