<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  ai-kb Phase 4 — webhook receiver LaunchAgent.

  HTTP server bound to 127.0.0.1:8765 by default. For external reachability
  put a reverse proxy (Caddy / nginx / Tailscale Funnel) in front; never bind
  this directly to a public interface — secrets are env-only.

  install-webhook.sh substitutes __VAULT__ and __PORT__ before copying to
  ~/Library/LaunchAgents/. Reads $VAULT/.env for secrets.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.aikb.webhook</string>

    <key>ProgramArguments</key>
    <array>
        <string>__VAULT__/.venv-webhook/bin/python3</string>
        <string>-m</string>
        <string>bin.webhook.cli</string>
        <string>serve</string>
        <string>--host</string>
        <string>127.0.0.1</string>
        <string>--port</string>
        <string>__PORT__</string>
        <string>--vault</string>
        <string>__VAULT__</string>
    </array>

    <key>WorkingDirectory</key>
    <string>__VAULT__</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
        <key>Crashed</key>
        <true/>
    </dict>

    <key>ThrottleInterval</key>
    <integer>10</integer>

    <key>StandardOutPath</key>
    <string>__VAULT__/.kb/webhook-stdout.log</string>

    <key>StandardErrorPath</key>
    <string>__VAULT__/.kb/webhook-stderr.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>KB_VAULT_ROOT</key>
        <string>__VAULT__</string>
    </dict>

    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>
